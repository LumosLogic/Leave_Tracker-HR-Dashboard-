{
  "name": "lumos-hrms",
  "version": "2.0.0",
  "description": "Lumos Logic HRMS — HR, Attendance, Leave, Payroll & Biometric Platform",
  "main": "backend/src/server.js",
  "scripts": {
    "start": "node backend/src/server.js",
    "dev": "nodemon backend/src/server.js",
    "dev:frontend": "cd client && npm run dev",
    "dev:platform": "cd platform-admin && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "build": "cd client && npm run build",
    "build:platform": "cd platform-admin && npm run build",
    "build:all": "npm run build && npm run build:platform"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.22.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "xlsx": "^0.18.5"
  }
}

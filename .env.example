# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
JWT_SECRET=generate-a-long-random-string-here-min-32-chars

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Local dev:    postgresql://lumos_admin:yourpass@localhost:5432/lumos_hrms
# Hostinger:   postgresql://lumos_admin:yourpass@YOUR_VPS_IP:5432/lumos_hrms
# AWS RDS:     postgresql://lumos_admin:yourpass@xxx.ap-south-1.rds.amazonaws.com:5432/lumos_hrms
DATABASE_URL=postgresql://lumos_admin:yourpassword@localhost:5432/lumos_hrms
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lumos_hrms
DB_USER=lumos_admin
DB_PASSWORD=yourpassword

# ─── Supabase (keep until PostgreSQL migration fully complete) ─────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Email (Google Workspace / Gmail SMTP) ─────────────────────────────────────
# Uses smtp.gmail.com:587 (hardcoded in emailService.js)
# App Password: Google Account → Security → 2FA → App Passwords
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=xxxx xxxx xxxx xxxx
PLATFORM_ADMIN_EMAIL=admin@yourdomain.com
HR_EMAIL=hr@yourdomain.com
COMPANY_HEAD_1_EMAIL=ceo@yourdomain.com
COMPANY_HEAD_2_EMAIL=coo@yourdomain.com

# ─── Google Calendar ───────────────────────────────────────────────────────────
# calendar.google.com → Settings → Integrate calendar → Calendar ID
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# For cloud deployments (paste service-account.json as single line):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ─── Cloudinary (document & receipt uploads) ───────────────────────────────────
# cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Web Push Notifications (VAPID) ───────────────────────────────────────────
# Generate keys once:
# node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

PORT=3000
JWT_SECRET=your-secret-key-change-in-production

# Supabase — get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gmail SMTP — use a Gmail address + an App Password (not your real password)
# Enable 2FA on Gmail, then go to: Google Account → Security → App Passwords
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Notification recipients for leave requests
HR_EMAIL=hr@yourcompany.com
COMPANY_HEAD_1_EMAIL=ceo@yourcompany.com
COMPANY_HEAD_2_EMAIL=coo@yourcompany.com

# Google Calendar Integration (optional — leave blank to disable)
# 1. Create a Google Cloud project, enable Calendar API, create a Service Account
# 2. Download the service account JSON key → save as service-account.json in project root
# 3. Share your calendar with the service account email (make changes to events permission)
# 4. Paste the Calendar ID below (calendar.google.com → Settings → Integrate calendar)
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# For cloud deployments instead of service-account.json file:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Cloudinary — for employee document and receipt uploads
# Get from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Database (PostgreSQL — for new deployments)
DATABASE_URL=postgresql://lumos_admin:yourpassword@localhost:5432/lumos_hrms

# Supabase (current — keep until PostgreSQL migration complete)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NODE_ENV=development
PORT=3000
JWT_SECRET=your_jwt_secret_here_at_least_32_chars

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
PLATFORM_ADMIN_EMAIL=

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Clockify
# (stored per-org in organizations table)

# Feature Flags (comma-separated keys to enable globally)
# ENABLED_FEATURES=payroll,expenses,assets
